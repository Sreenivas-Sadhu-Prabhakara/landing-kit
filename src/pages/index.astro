---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site } from '../site.config.mjs';

// ── Content the subagent fills in per product ──────────────────
const features = [
  {
    title: 'SEO-perfect by default',
    body: 'Every page ships with clean meta tags, Open Graph, JSON-LD structured data, and an auto-generated sitemap — so Google indexes and ranks your landing page from day one.',
  },
  {
    title: 'Waitlist + analytics baked in',
    body: 'Capture early signups with a built-in waitlist form and track every visitor with analytics wired up out of the box. Measure demand before you write a line of product code.',
  },
  {
    title: 'Astro-fast, ~100 Lighthouse',
    body: 'Static, zero-bloat pages built on Astro load instantly and score near-perfect Lighthouse marks — fast sites convert better and rank higher.',
  },
  {
    title: 'One-command deploy',
    body: 'Ship to GitHub Pages or Vercel with a single command. No servers to configure, no pipelines to babysit — your landing page is live in minutes.',
  },
  {
    title: 'Proven copy blocks & templates',
    body: 'Start from battle-tested hero, feature, FAQ, and CTA blocks written to convert. Swap in your idea and launch — no blank-page paralysis.',
  },
];

const faqs = [
  {
    q: 'What is ' + site.name + '?',
    a: 'Landing Kit is a micro SaaS launch kit that spins up a fast, SEO-optimized SaaS landing page template with a waitlist and analytics baked in — so you can validate a startup idea this afternoon instead of building for a month.',
  },
  {
    q: 'Do I need to know how to code?',
    a: 'Very little. Landing Kit ships with proven copy blocks and templates you edit in plain config files. If you can change text and run one deploy command, you can launch a professional landing page.',
  },
  {
    q: 'How is the SEO handled?',
    a: 'SEO is perfect by default. Every page includes optimized meta tags, Open Graph and Twitter cards, JSON-LD structured data, and an auto-generated sitemap and robots.txt — the same setup an SEO landing page generator would give you, without the manual work.',
  },
  {
    q: 'What does it cost?',
    a: 'Free to start. No credit card required. Join the waitlist to get early access.',
  },
];

// FAQ structured data for rich results
const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout>
  <script
    slot="header"
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(faqJsonLd)}
  />
  <Header slot="header" />

  <!-- Hero -->
  <section class="mx-auto max-w-4xl px-6 pb-16 pt-20 text-center">
    <p class="mb-4 inline-block rounded-full bg-brand-50 px-4 py-1 text-sm font-semibold text-brand-700">
      {site.organization}
    </p>
    <h1 class="text-balance text-5xl font-extrabold tracking-tight sm:text-6xl">
      {site.tagline}
    </h1>
    <p class="mx-auto mt-6 max-w-2xl text-lg text-[var(--muted)]">
      {site.description}
    </p>
    <div class="mt-10 flex justify-center gap-4">
      <a
        href="#cta"
        class="rounded-xl bg-brand-600 px-7 py-3.5 text-base font-semibold text-white shadow-lg shadow-brand-600/20 transition hover:bg-brand-700"
        >Get started free</a
      >
      <a
        href="#features"
        class="rounded-xl border border-[var(--border)] px-7 py-3.5 text-base font-semibold transition hover:bg-[var(--card)]"
        >See how it works</a
      >
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="mx-auto max-w-6xl px-6 py-16">
    <h2 class="text-center text-3xl font-bold tracking-tight">Everything you need</h2>
    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        features.map((f) => (
          <div class="rounded-2xl border border-[var(--border)] bg-[var(--card)] p-6">
            <h3 class="text-lg font-semibold">{f.title}</h3>
            <p class="mt-2 text-[var(--muted)]">{f.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="mx-auto max-w-3xl px-6 py-16">
    <h2 class="text-center text-3xl font-bold tracking-tight">Frequently asked questions</h2>
    <div class="mt-10 divide-y divide-[var(--border)]">
      {
        faqs.map((f) => (
          <details class="group py-5">
            <summary class="cursor-pointer list-none text-lg font-semibold">
              {f.q}
            </summary>
            <p class="mt-3 text-[var(--muted)]">{f.a}</p>
          </details>
        ))
      }
    </div>
  </section>

  <!-- CTA / waitlist -->
  <section id="cta" class="mx-auto max-w-3xl px-6 py-20 text-center">
    <div class="rounded-3xl border border-[var(--border)] bg-brand-600 px-8 py-14 text-white">
      <h2 class="text-3xl font-bold">Ready to try {site.name}?</h2>
      <p class="mx-auto mt-3 max-w-md text-brand-100">
        Join the early users. It's free to start.
      </p>
      <!-- Replace action with a real backend/waitlist endpoint per product -->
      <form
        class="mx-auto mt-8 flex max-w-md gap-3"
        action="#"
        method="post"
        data-waitlist
      >
        <input
          type="email"
          name="email"
          required
          placeholder="you@work.com"
          class="w-full rounded-lg px-4 py-3 text-[var(--fg)]"
        />
        <button
          type="submit"
          class="whitespace-nowrap rounded-lg bg-white px-6 py-3 font-semibold text-brand-700 transition hover:bg-brand-50"
          >Join</button
        >
      </form>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
